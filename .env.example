# ===========================================
# VARIABLE OBLIGATORIA: local | demo | production
# ===========================================
APP_ENV=local

# ===========================================
# APLICACIÓN
# ===========================================
APP_NAME="empresaIMO Digital"
APP_URL=http://127.0.0.1/empresaIMO/public
APP_SECRET=GenerateRandom32CharStringHere!
APP_TIMEZONE=America/Argentina/Buenos_Aires
APP_CHARSET=utf8mb4
APP_LOCALE=es

# ===========================================
# BASE DE DATOS
# ===========================================
DB_HOST=127.0.0.1
DB_NAME=empresaIMO_db
DB_USER=root
DB_PASS=

# ===========================================
# REDIS (INFRAESTRUCTURA)
# ===========================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ===========================================
# SEGURIDAD Y JWT
# ===========================================
JWT_SECRET=super-secret-token-change-this
JWT_TTL=3600
REFRESH_TOKEN_TTL=2592000

SESSION_LIFETIME=14400
SESSION_HEARTBEAT=300
SESSION_WARNING=300

# ===========================================
# SECURITY HARDENING
# ===========================================
AUTH_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_DECAY=60
AUTH_BRUTE_FORCE_BLOCK=1800
AUTH_ACCOUNT_LOCK=900
AUTH_HASH_ALGO=argon2id
GLOBAL_RATE_LIMIT=100
GLOBAL_RATE_LIMIT_WINDOW=60

# ===========================================
# EMAIL
# ===========================================
MAIL_ENABLED=false
MAIL_QUEUE=false
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=contacto@empresaIMO.com
MAIL_FROM_NAME="empresaIMO Support"

# ===========================================
# TIPOGRAFÍA Y ESTÉTICA (UX / BRANDING)
# ===========================================
FONT_URL="https://fonts.googleapis.com/css2?family=Manrope:wght@400;700;800&family=Inter:wght@400;500;600&family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap"
FONT_HEADING="'Manrope', sans-serif"
FONT_BODY="'Inter', sans-serif"
FONT_MONO="monospace"
TYPO_SCALE_RATIO=1.333

# ===========================================
# UI — DESIGN SYSTEM TOKENS (Color Palette)
# ===========================================
UI_COLOR_BG_LIGHT="#faf8ff"
UI_COLOR_SURFACE_LIGHT="#ffffff"
UI_COLOR_BORDER_LIGHT="rgba(197, 198, 210, 0.4)"
UI_PRIMARY_COLOR="#00113a"
UI_SECONDARY_COLOR="#002366"
UI_GOLD_COLOR="#4edea3"
UI_COLOR_SUCCESS="#00a371"
UI_COLOR_WARNING="#ffdad6"
UI_COLOR_DANGER="#ba1a1a"
UI_COLOR_INFO="#758dd5"
UI_RADIUS_SM="6px"
UI_RADIUS_MD="12px"
UI_RADIUS_LG="20px"
UI_RADIUS_PILL="50rem"

# ===========================================
# PARÁMETROS DE NEGOCIO (SLA & BRANDING)
# ===========================================
COMPANY_NAME="empresaIMO"
COMPANY_SLOGAN="Arquitectura resiliente de alto rendimiento bajo entornos HIPAA"
COMPANY_MAIL="contacto@empresaIMO.com"
COMPANY_PHONE="+1 (555) 000-0000"
COMPANY_ADDRESS="San Antonio, TX, USA"
COMPANY_EST_YEAR="2024"

SLA_RESPONSE_TIME="24h"
CURRENCY_SYMBOL="$"
TAX_RATE=0.21
SHOW_ENTERPRISE_PROFILE=false
COMPANY_YEARS_EXP=10
COMPANY_PROJECTS_DELIVERED=45

# ===========================================
# SOCIAL MEDIA links
# ===========================================
SOCIAL_INSTAGRAM="https://www.instagram.com/empresaIMO/"
SOCIAL_LINKEDIN="https://www.linkedin.com/company/empresaIMO/"
SOCIAL_TWITTER="https://twitter.com/empresaIMO"
SOCIAL_GITHUB="#"
SOCIAL_FACEBOOK="#"

# ===========================================
# RBAC & INTELLIGENCE
# ===========================================
RBAC_MODE=granular
LEAD_SCORING_ENABLED=true
ROI_METRICS_ENABLED=true
INTERNAL_EVENTS_ENABLED=true

# ===========================================
# PASARELAS DE PAGO (MERCADOPAGO)
# ===========================================
MP_ACCESS_TOKEN=tu-access-token-aqui
MP_PUBLIC_KEY=tu-public-key-aqui
MP_CURRENCY_ID=USD
MP_EXCHANGE_RATE=1.00

# ===========================================
# INSTRUCCIONES BANCARIAS
# ===========================================
BANK_NAME="Digital EmpresaIMO Financial"
BANK_ACCOUNT_NAME="empresaIMO LLC"
BANK_ACCOUNT_NUMBER="1234-5678-9012"
BANK_CBU_ALIAS="empresaIMO.usd"

# ===========================================
# MODULO GAI (GENERATIVE AI)
# ===========================================
AI_PROVIDER="groq"
AI_MODEL="llama-3.1-8b-instant"
AI_API_KEY="tu-api-key"
